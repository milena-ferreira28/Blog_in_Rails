<div class="container">
  <%= form_with model: article do |form| %>
    <div class="field">
      <%= form.label :title %><br>
      <%= form.text_field :title %>
      <% article.errors.full_messages_for(:title).each do |message| %>
        <div class="error-message"><%= message %></div>
      <% end %>
    </div>

    <div class="field">
      <%= form.label :body %><br>
      <%= form.text_area :body %>
      <% article.errors.full_messages_for(:body).each do |message| %>
        <div class="error-message"><%= message %></div>
      <% end %>
    </div>

    <div class="field">
      <%= form.label :cover_image, "Cover Image URL" %><br>
      <%= form.text_field :cover_image, placeholder: "https://..." %>
    </div>

    <div class="field">
      <%= form.label :status %><br>
      <%= form.select :status, ['public', 'private', 'archived'], selected: 'public' %>
    </div>

    <div class="actions">
      <%= form.submit %>
    </div>
  <% end %>

  <%= link_to "Back", articles_path, class: "back-link" %>
</div>
